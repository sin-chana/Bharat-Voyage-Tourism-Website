# --- API server (required for auth, bookings, payments, favorites) ---
# Copy to .env.local or export in your shell. Never commit real secrets.

SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
PORT=3001
CLIENT_ORIGIN=http://localhost:3000
DATABASE_PATH=./data/voyage.db

# Optional: create first admin on empty database (password min 8 chars)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMeNow!

# Session lifetime (ms)
SESSION_MAX_AGE_MS=86400000
SESSION_ABSOLUTE_MAX_MS=604800000

# Rate limits (optional overrides)
# RATE_LIMIT_LOGIN_MAX=5
# RATE_LIMIT_REGISTER_MAX=3
# RATE_LIMIT_API_MAX=300

# UPI QR payload (display only — no real money movement in sandbox)
UPI_VPA=merchant@upi
UPI_PAYEE_NAME=Voyage Bharat

# --- Gemini chatbot ---
# Keep this key server-side only. The chatbot reads it from the Express API.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Optional OpenAI text generation ---
# If provided, chatbot will try OpenAI first and fall back to Gemini/local data.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# --- Optional PlayHT text-to-speech for assistant audio replies ---
# PLAY_HT_API_KEY=
# PLAY_HT_USER_ID=
# PLAY_HT_VOICE_ID=
